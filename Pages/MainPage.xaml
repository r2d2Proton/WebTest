<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:WebTest.PageModels"             
             xmlns:models="clr-namespace:WebTest.Models"
             xmlns:controls="clr-namespace:WebTest.Pages.Controls"
             xmlns:pullToRefresh="clr-namespace:Syncfusion.Maui.Toolkit.PullToRefresh;assembly=Syncfusion.Maui.Toolkit"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="WebTest.Pages.MainPage"
             x:DataType="pageModels:MainPageModel"
             x:Name="OverviewPage"
             Title="{Binding Today}">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
                BindingContext="{Binding Path=BindingContext, Source={x:Reference OverviewPage}, x:DataType=ContentPage}"
                EventName="NavigatedTo"
                Command="{Binding NavigatedToCommand}" />
        <toolkit:EventToCommandBehavior
                BindingContext="{Binding Path=BindingContext, Source={x:Reference OverviewPage}, x:DataType=ContentPage}"
                EventName="NavigatedFrom"
                Command="{Binding NavigatedFromCommand}" />
        <toolkit:EventToCommandBehavior
                BindingContext="{Binding Path=BindingContext, Source={x:Reference OverviewPage}, x:DataType=ContentPage}"
                EventName="Appearing"                
                Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />

            <Color x:Key="FocusedColor">#00A3FF</Color>
            <Color x:Key="UnfocusedColor">Transparent</Color>
            <toolkit:BoolToObjectConverter x:Key="FocusToColorConverter"
                               TrueObject="{StaticResource FocusedColor}"
                               FalseObject="{StaticResource UnfocusedColor}" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <pullToRefresh:SfPullToRefresh
            IsRefreshing="{Binding IsRefreshing}"
            RefreshCommand="{Binding RefreshCommand}">
            <pullToRefresh:SfPullToRefresh.PullableContent>
                <ScrollView>
                    <Grid Padding="{StaticResource LayoutPadding}" RowSpacing="{StaticResource LayoutSpacing}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Text="Task Categories" Style="{StaticResource Title2}" SemanticProperties.HeadingLevel="Level1"/>
                        <controls:CategoryChart Grid.Row="1" />
                        <Label Grid.Row="2" Text="Projects" Style="{StaticResource Title2}" SemanticProperties.HeadingLevel="Level1"/>
                        <CollectionView Grid.Row="3" ItemsSource="{Binding Projects}"
                                        Margin="-7.5,0"
                                        MinimumHeightRequest="250"
                                        x:Name="ProjectsCollectionView"
                                        SelectionMode="Single"
                                        SelectedItem="{Binding SelectedProject}"
                                        SelectionChangedCommand="{Binding NavigateToProjectCommand, Source={RelativeSource AncestorType={x:Type pageModels:MainPageModel}}, x:DataType=pageModels:MainPageModel}"
                                        SelectionChangedCommandParameter="{Binding SelectedProject}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="7.5"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Project">
                                    <controls:ProjectCardView WidthRequest="200" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- LOTTIE ROW -->
                        <Grid Grid.Row="4" Padding="0,20" RowSpacing="15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Three evenly spaced Lottie WebViews -->
                            <Grid Grid.Row="0" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        x:Name="LottieLeftFrame"
                                        Stroke="Transparent"
                                        StrokeThickness="4"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="Transparent"
                                        Padding="0">
                                    <WebView x:Name="LottieViewLeft"
                                             HeightRequest="300"
                                             HorizontalOptions="Fill"
                                             Focused="OnLottieFocused"
                                             Unfocused="OnLottieUnfocused"/>
                                </Border>

                                <Border Grid.Column="1"
                                        x:Name="LottieMiddleFrame"
                                        Stroke="Transparent"
                                        StrokeThickness="4"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="Transparent"
                                        Padding="0">
                                    <WebView x:Name="LottieViewMiddle"
                                             HeightRequest="300"
                                             HorizontalOptions="Fill"
                                             Focused="OnLottieFocused"
                                             Unfocused="OnLottieUnfocused"/>
                                </Border>

                                <Border Grid.Column="2"
                                        x:Name="LottieRightFrame"
                                        Stroke="Transparent"
                                        StrokeThickness="4"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="Transparent"
                                        Padding="0">
                                    <WebView x:Name="LottieViewRight"
                                             HeightRequest="300"
                                             HorizontalOptions="Fill"
                                             Focused="OnLottieFocused"
                                             Unfocused="OnLottieUnfocused"/>
                                </Border>
                            </Grid>

                            <!-- Lottie Controls -->
                            <VerticalStackLayout Grid.Row="1" 
                                                 HorizontalOptions="Center"
                                                 Spacing="10"
                                                 Padding="0,10">
                                <Label Text="Lottie Controls" 
                                       HorizontalOptions="Center"
                                       FontSize="12"/>
                                <HorizontalStackLayout HorizontalOptions="Center"
                                                       Spacing="20"
                                                       Padding="0">
                                    <Button Text="▶ Play"
                                            Clicked="OnPlayLottieClicked"
                                            Padding="15,8"
                                            FontSize="14"/>
                                    <Button Text="⏸ Pause"
                                            Clicked="OnPauseLottieClicked"
                                            Padding="15,8"
                                            FontSize="14"/>
                                    <Button Text="⏹ Stop"
                                            Clicked="OnStopLottieClicked"
                                            Padding="15,8"
                                            FontSize="14"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- ANIMATION ROW -->
                        <Grid Grid.Row="5" Padding="0,20" RowSpacing="15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Two evenly spaced Animation WebViews -->
                            <Grid Grid.Row="0" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        x:Name="AnimationLeftFrame"
                                        Stroke="Transparent"
                                        StrokeThickness="4"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="Transparent"
                                        Padding="0">
                                    <WebView x:Name="AnimationViewLeft"
                                             HeightRequest="300"
                                             HorizontalOptions="Fill"
                                             Focused="OnAnimationFocused"
                                             Unfocused="OnAnimationUnfocused"/>
                                </Border>

                                <Border Grid.Column="1"
                                        x:Name="AnimationRightFrame"
                                        Stroke="Transparent"
                                        StrokeThickness="4"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="Transparent"
                                        Padding="0">
                                    <WebView x:Name="AnimationViewRight"
                                             HeightRequest="300"
                                             HorizontalOptions="Fill"
                                             Focused="OnAnimationFocused"
                                             Unfocused="OnAnimationUnfocused"/>
                                </Border>
                            </Grid>

                            <!-- Animation Controls -->
                            <VerticalStackLayout Grid.Row="1"
                                                 HorizontalOptions="Center"
                                                 Spacing="10"
                                                 Padding="0,10">
                                <Label Text="Animation Controls"
                                       HorizontalOptions="Center"
                                       FontSize="12"/>
                                <HorizontalStackLayout HorizontalOptions="Center"
                                                       Spacing="20"
                                                       Padding="0">
                                    <Button Text="▶ Play"
                                            Clicked="OnPlayAnimationClicked"
                                            Padding="15,8"
                                            FontSize="14"/>
                                    <Button Text="⏸ Pause"
                                            Clicked="OnPauseAnimationClicked"
                                            Padding="15,8"
                                            FontSize="14"/>
                                    <Button Text="⏹ Stop"
                                            Clicked="OnStopAnimationClicked"
                                            Padding="15,8"
                                            FontSize="14"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>

                        <Grid Grid.Row="6" MinimumHeightRequest="44">
                            <Label Text="Tasks" Style="{StaticResource Title2}" VerticalOptions="Center" SemanticProperties.HeadingLevel="Level1"/>
                            <ImageButton 
                                Source="{StaticResource IconClean}"
                                HorizontalOptions="End"
                                VerticalOptions="Center"
                                Aspect="Center"
                                HeightRequest="44"
                                WidthRequest="44"
                                IsVisible="{Binding HasCompletedTasks}"
                                Command="{Binding CleanTasksCommand}"
                                SemanticProperties.Description="Clean tasks" />
                        </Grid>
                        <VerticalStackLayout Grid.Row="7" Spacing="15"
                            BindableLayout.ItemsSource="{Binding Tasks}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <controls:TaskView TaskCompletedCommand="{Binding TaskCompletedCommand, Source={RelativeSource AncestorType={x:Type pageModels:MainPageModel}}, x:DataType=pageModels:MainPageModel}" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </Grid>
                </ScrollView>
            </pullToRefresh:SfPullToRefresh.PullableContent>
        </pullToRefresh:SfPullToRefresh>

        <controls:AddButton 
            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
            Command="{Binding AddTaskCommand}"
            ToolTipProperties.Text="Add task"
            SemanticProperties.Description="Add task" />
    </Grid>
</ContentPage>
